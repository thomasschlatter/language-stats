{
  "name": "language-stats",
  "version": "0.1.0",
  "description": "A community website for sharing language-learning tips and building a clickable, graph-linked dictionary. First language: German.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "seed": "node server/db/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "language",
    "learning",
    "dictionary",
    "graph",
    "german"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  }
}
