{
  "name": "language-stats",
  "version": "0.1.0",
  "description": "A community website for sharing language-learning tips and building a clickable, graph-linked dictionary. First language: German.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "seed": "node server/db/seed.js",
    "scrape": "node server/scripts/scrape.js",
    "test": "node --test",
    "world:install": "cd world && npm install && cd client && npm install",
    "world:server": "cd world && npm start",
    "world:client": "cd world/client && npm run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "language",
    "learning",
    "dictionary",
    "graph",
    "german"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "adm-zip": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "franc": "^6.2.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "opencc-js": "^1.4.1"
  }
}
