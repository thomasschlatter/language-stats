# Copy this file to .env and adjust as needed.

# Port the API + static server listens on
PORT=3000

# Secret used to sign auth tokens (JWT). CHANGE THIS in any real deployment.
JWT_SECRET=change-me-to-a-long-random-string

# How long a login session lasts
TOKEN_TTL=7d

# Public URL of the separately deployed World client. Required in production.
# WORLD_URL=https://world.example.com
